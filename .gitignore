!**/Sound/*.wav
!**/Sound/*.ogg

# Third-party mod source (not redistributable, see manifest.csv)
# Only Waka* mods belong in this repo

# Excluded from initial OSS commit — stored privately
# WakaPet: WIP, large authoring assets (Blender 130MB+) and IP-sensitive history
# WakaCopper: disabled in modlist, large shipping bundles (.unity3d 125MB)
mods/WakaPet/
mods/WakaCopper/

# Large authoring/asset binaries (use Git LFS if any of these need committing)
*.blend
*.blend1
*.fbx
*.unity3d
*.unity3d.bak
*.unity3d.v*_backup
*.psd
*.tga
