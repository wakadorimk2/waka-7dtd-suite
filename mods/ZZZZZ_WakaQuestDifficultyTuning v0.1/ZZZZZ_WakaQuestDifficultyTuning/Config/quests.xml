<!-- ==================================================================== -->
<!-- 9. ultrainfested 再調整: spawn/GS を抑えて "選べる難クエ"枠に          -->
<!--    QuestRevamp Gears Edition の tier2_clear_ultrainfested は          -->
<!--    実は <variable> で定義されている (quests_gears.xml L209-211)。      -->
<!--    tier3-6 は template="tier2_clear_ultrainfested" 継承で自動反映され -->
<!--    るため、tier2 のみ書き換えれば全 tier に伝播する。                 -->
<!--    (v0.3 までの property/個別variable patch全失敗バグを修正)          -->
<!-- ==================================================================== -->

<!-- tier2 のみ書き換え → tier3-6 はtemplate継承で同値になる -->
<set xpath="/quests/quest[@id='tier2_clear_ultrainfested']/variable[@name='spawn_multiplier']/@value">4</set>
<set xpath="/quests/quest[@id='tier2_clear_ultrainfested']/variable[@name='gamestage_mod']/@value">.85</set>
<set xpath="/quests/quest[@id='tier2_clear_ultrainfested']/variable[@name='gamestage_bonus']/@value">30</set>


<!-- ==================================================================== -->
<!-- 10. trader rotation 重み増し                                         -->
<!--    Revamp の挿入分 (各tier 1件) に加えて super系をもう1件ずつ挿入。   -->
<!--    super系は抽選確率 ×2 になる。                                     -->
<!--    tier1 super は tier1 グループ内 (tier1_buried_supplies の後) に    -->
<!--    挿入することで tier1 抽選から確実に拾える位置に置く。              -->
<!--    ultra/nightmare は既存の頻度を維持 (=低頻度の"目標枠")            -->
<!-- ==================================================================== -->

<!-- tier1 super: tier1 グループ末尾 (tier1_buried_supplies 後) に2件挿入 -->
<insertAfter xpath="/quests/quest_list[@id='trader_rekt_quests' or @id='trader_jen_quests' or @id='trader_bob_quests' or @id='trader_hugh_quests' or @id='trader_joel_quests']/quest[@id='tier1_buried_supplies']">
    <quest id="tier1_clear_superinfested"/>
    <quest id="tier1_clear_superinfested"/>
</insertAfter>

<!-- tier2-6 super: 既存 Revamp 挿入 (tier6_clear_infested 後) と同じ位置にもう1件ずつ -->
<insertAfter xpath="/quests/quest_list[@id='trader_rekt_quests' or @id='trader_jen_quests' or @id='trader_bob_quests' or @id='trader_hugh_quests' or @id='trader_joel_quests']/quest[@id='tier6_clear_infested']">
    <quest id="tier2_clear_superinfested"/>
    <quest id="tier3_clear_superinfested"/>
    <quest id="tier4_clear_superinfested"/>
    <quest id="tier5_clear_superinfested"/>
    <quest id="tier6_clear_superinfested"/>
</insertAfter>


<!-- ==================================================================== -->
<!-- 11. v0.5: 純弾薬枠を "trap option" 化 (value=4 → 1)                    -->
<!--                                                                      -->
<!-- 背景: super/ultra/nightmare の reward block は 純弾薬枠 value=4 ＋    -->
<!--       混合枠 value=3×2 の計 ammo 3 lines。choices_count=10-11 と相俟  -->
<!--       って「ammo 選んどけば確実に潤う」=choices ガチャの意味が薄れる。-->
<!--                                                                      -->
<!-- 対策: 純弾薬枠 (id='groupQuestAmmo' 完全一致) のみ value=1 に setattr。-->
<!--       混合枠 (id list) は維持 → ammo狙いなら混合枠で薄まる、         -->
<!--       武器/アーマー/ツール/Crafting 枠が相対的に映える。              -->
<!--                                                                      -->
<!-- 対象: tier1_clear_superinfested (Waka自前) + tier2-6 super/ultra/     -->
<!--       nightmare (Quest Revamp-Gears 由来) = 計 16 quests。            -->
<!--       priority は Revamp 後ロードなので append 後の setattribute が   -->
<!--       問題なく当たる。                                                -->
<!-- ==================================================================== -->
<setattribute xpath="/quests/quest[contains(@id,'_superinfested') or contains(@id,'_ultrainfested') or contains(@id,'_nightmare')]/reward[@type='LootItem' and @id='groupQuestAmmo']" name="value">1</setattribute>

</configs>
