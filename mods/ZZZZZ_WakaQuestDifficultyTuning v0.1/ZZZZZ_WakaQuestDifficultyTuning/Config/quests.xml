<configs>

<!-- ==================================================================== -->
<!-- Waka Quest Difficulty Tuning v0.4                                     -->
<!--                                                                      -->
<!-- v0.3 → v0.4 変更:                                                    -->
<!--  user feedback: "通常10択 vs super 4択" の歪みで難クエの価値が消える、 -->
<!--  tier別 +1/tier の段階的スケーリングに統合。super は通常+2、         -->
<!--  ultra/nightmare は通常+3 で "更に豪華" な感触を担保。                -->
<!--                                                                      -->
<!-- choices_count マトリクス:                                            -->
<!--          Normal  Super  Ultra  Nightmare                             -->
<!--   tier1    3      5      -      -                                    -->
<!--   tier2    4      6      7      7                                    -->
<!--   tier3    5      7      8      8                                    -->
<!--   tier4    6      8      9      9                                    -->
<!--   tier5    7      9     10     10                                    -->
<!--   tier6    8     10     11     11                                    -->
<!--                                                                      -->
<!-- value scaling (Waka append 分):                                      -->
<!--   super = tier + 1                                                   -->
<!--   ultra = tier + 2                                                   -->
<!--   nightmare = tier + 2                                               -->
<!--                                                                      -->
<!-- 豪華 decor:                                                          -->
<!--   tier4+ super/ultra/nightmare: groupCraftingRare                    -->
<!--   tier6 super/ultra/nightmare: resourceLegendaryParts isfixed        -->
<!--                                                                      -->
<!-- 実装メモ:                                                            -->
<!--  - 既存 property を持つ template には <setattribute> で書き換え      -->
<!--  - template継承で property を持たない子 quest には <append> で追加   -->
<!--    (子の property は親 template の property をオーバーライドする)    -->
<!--  - FNS Make Quest Rewards Great Again の "全 tier* = 10 一律" を     -->
<!--    後ロードでこのスケーリングに上書きする                            -->
<!-- ==================================================================== -->


<!-- ==================================================================== -->
<!-- 1. tier1_clear_superinfested 新設                                    -->
<!--    (敵数増し・敵質ぬるめ＝現装備で挑める"ちょい盛り"枠)             -->
<!--    v0.4: choices=5 (tier1 super)、LootItem 10枠で variety 確保         -->
<!-- ==================================================================== -->
<insertAfter xpath="/quests/quest[@id='tier6_clear_nightmare']">
    <quest id="tier1_clear_superinfested">
        <property name="name_key" value="quest_tier1_superinfested_clear"/>
        <property name="subtitle_key" value="quest_superinfestation_subtitle"/>
        <property name="description_key" value="quest_tier1_superinfested_clear_offer"/>
        <property name="icon" value="ui_game_symbol_quest"/>
        <property name="category_key" value="quest"/>
        <property name="offer_key" value="quest_tier1_superinfested_clear_offer"/>
        <property name="repeatable" value="true"/>
        <property name="difficulty_tier" value="1"/>
        <property name="statement_key" value="quest_infestation_statement"/>
        <property name="response_key" value="quest_superinfestation_response1"/>
        <property name="login_rally_reset" value="true"/>
        <property name="reward_choices_count" value="5"/>
        <property name="extra_tags" value="infested"/>
        <property name="shareable" value="true"/>
        <property name="spawn_multiplier" value="2"/>
        <property name="gamestage_mod" value=".7"/>
        <property name="gamestage_bonus" value="20"/>
        <property name="completiontype" value="TurnIn"/>
        <property name="completion_key" value="quest_clear_completion"/>
        <objective type="RandomPOIGoto">
            <property name="phase" value="1"/>
            <property name="biome_filter_type" value="SameBiome"/>
            <property name="biome_filter" value=""/>
            <property name="nav_object" value="quest"/>
            <property name="poi_tier" value="-1"/>
        </objective>
        <objective type="RallyPoint">
            <property name="phase" value="2"/>
            <property name="nav_object" value="rally"/>
            <property name="rally_marker_type" value="questRallyMarkerInfestation"/>
        </objective>
        <objective type="ClearSleepers">
            <property name="phase" value="3"/>
            <property name="nav_object" value="sleeper_volume"/>
        </objective>
        <objective type="POIStayWithin">
            <property name="phase" value="3"/>
            <property name="radius" value="25"/>
        </objective>
        <action type="UnlockPOI">
            <property name="phase" value="4"/>
        </action>
        <objective type="ReturnToNPC">
            <property name="phase" value="4"/>
            <property name="nav_object" value="return_to_trader"/>
        </objective>
        <objective type="InteractWithNPC">
            <property name="phase" value="4"/>
            <property name="nav_object" value="return_to_trader"/>
        </objective>
        <reward type="Exp" value="4500"/>
        <reward type="Item" id="casinoCoin" value="750"/>
        <reward type="LootItem" id="groupQuestAmmo" ischosen="true" value="2"/>
        <reward type="LootItem" id="groupQuestSchematics" ischosen="true" value="2"/>
        <reward type="LootItem" id="groupQuestMods" ischosen="true" value="2"/>
        <reward type="LootItem" id="groupQuestFood,groupQuestMedical" ischosen="true" value="2"/>
        <reward type="LootItem" id="groupQuestResourcesT0,groupQuestT1SkillMagazineBundle" ischosen="true" value="2"/>
        <reward type="LootItem" id="groupCraftingUncommon" ischosen="true" value="1"/>
        <reward type="LootItem" id="groupQuestAmmo,groupQuestSchematics,groupQuestMods" ischosen="true" value="2"/>
        <reward type="LootItem" id="groupQuestWeapons,groupQuestArmor" ischosen="true" value="1"/>
        <reward type="LootItem" id="groupQuestTools,groupQuestArmorResources" ischosen="true" value="2"/>
        <reward type="LootItem" id="groupQuestWeaponsRangedT1,groupQuestMods" ischosen="true" value="1"/>
    </quest>
</insertAfter>


<!-- ==================================================================== -->
<!-- 2. choices_count tier別スケーリング (Normal)                          -->
<!--   tier1=3, tier2=4, tier3=5, tier4=6, tier5=7, tier6=8                -->
<!-- ==================================================================== -->

<!-- tier1 normal templates (own property): tier1_clear, tier1_fetch, tier1_buried_supplies → 3 -->
<setattribute xpath="/quests/quest[@id='tier1_clear' or @id='tier1_fetch' or @id='tier1_buried_supplies']/property[@name='reward_choices_count']" name="value">3</setattribute>

<!-- tier2 normal templates (own property): tier2_clear_infested, tier2_restore_power, tier2_fetch_clear → 4 -->
<setattribute xpath="/quests/quest[@id='tier2_clear_infested' or @id='tier2_restore_power' or @id='tier2_fetch_clear']/property[@name='reward_choices_count']" name="value">4</setattribute>

<!-- tier2 normal children (template継承、property無し): clear, fetch, buried_supplies → append 4 -->
<append xpath="/quests/quest[@id='tier2_clear' or @id='tier2_fetch' or @id='tier2_buried_supplies']">
    <property name="reward_choices_count" value="4"/>
</append>

<!-- tier3 normal children (全て継承) → append 5 -->
<append xpath="/quests/quest[@id='tier3_clear' or @id='tier3_fetch' or @id='tier3_buried_supplies' or @id='tier3_clear_infested' or @id='tier3_restore_power' or @id='tier3_fetch_clear']">
    <property name="reward_choices_count" value="5"/>
</append>

<!-- tier4 normal children → append 6 -->
<append xpath="/quests/quest[@id='tier4_clear' or @id='tier4_clear_infested' or @id='tier4_restore_power' or @id='tier4_fetch_clear']">
    <property name="reward_choices_count" value="6"/>
</append>

<!-- tier5 normal children → append 7 -->
<append xpath="/quests/quest[@id='tier5_clear' or @id='tier5_clear_infested' or @id='tier5_fetch_clear']">
    <property name="reward_choices_count" value="7"/>
</append>

<!-- tier6 normal children → append 8 -->
<append xpath="/quests/quest[@id='tier6_clear_infested']">
    <property name="reward_choices_count" value="8"/>
</append>


