<?xml version="1.0" encoding="UTF-8"?>
<configs>
    <!--
        Black Wolf adds Pack Mule gated CarryCapacity to vanilla pocket mods.
        Rescale those additions for the 91-slot Waka bag so pockets matter
        without pushing completed builds far past the UI capacity.
    -->

    <!-- Storage Pocket: vanilla +1, Pack Mule bonus +0/+1/+1/+2/+2. -->
    <set xpath="/item_modifiers/item_modifier[@name='modArmorStoragePocket']/effect_group/passive_effect[@name='CarryCapacity'][requirement[@progression_name='perkPackMule' and @value='1']]/@value">0</set>
    <set xpath="/item_modifiers/item_modifier[@name='modArmorStoragePocket']/effect_group/passive_effect[@name='CarryCapacity'][requirement[@progression_name='perkPackMule' and @value='2']]/@value">1</set>
    <set xpath="/item_modifiers/item_modifier[@name='modArmorStoragePocket']/effect_group/passive_effect[@name='CarryCapacity'][requirement[@progression_name='perkPackMule' and @value='3']]/@value">1</set>
    <set xpath="/item_modifiers/item_modifier[@name='modArmorStoragePocket']/effect_group/passive_effect[@name='CarryCapacity'][requirement[@progression_name='perkPackMule' and @value='4']]/@value">2</set>
    <set xpath="/item_modifiers/item_modifier[@name='modArmorStoragePocket']/effect_group/passive_effect[@name='CarryCapacity'][requirement[@progression_name='perkPackMule' and @value='5']]/@value">2</set>

