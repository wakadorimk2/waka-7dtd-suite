	<!-- ================================================================ -->
	<!-- v1.2: IZY guns isolation                                         -->
	<!-- IZY's 11 sub-packs inject ~60 guns into groupRangedAll, which    -->
	<!-- dominates trader rolls and crowds out EFTX/vanilla guns.         -->
	<!-- Strategy: remove all IZYgun* from groupRangedAll, give them      -->
	<!-- dedicated WakaIZYTraderGunsT1-T5 groups + per-trader 0,1 slots.  -->
	<!-- Achieves EFTX/IZY/vanilla parity in trader stock.                -->
	<!--                                                                  -->
	<!-- ORDER MATTERS: this mod's folder must load AFTER all IZY packs   -->
	<!-- (ZZZ_ prefix ensures this), else <remove> finds nothing.         -->
	<!-- T0 junk-tier IZY guns are bundled into T1 for EFTX-parity.       -->
	<!-- prob="0.5" (T4 rare) and "0.3" (T5 super rare) are preserved.    -->
	<!-- ================================================================ -->
	<remove xpath="//trader_item_group[@name='groupRangedAll']/item[starts-with(@name, 'IZYgun')]"/>

