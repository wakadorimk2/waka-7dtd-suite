	<!-- ================================================================ -->
	<!-- 2. T0 starter chests: seed real firearms sparingly alongside    -->
	<!-- pipe guns so early game has occasional "found treasure" moments. -->
	<!-- E[EV/chest] ≒ 0.20 × 500 = 100                                  -->
	<!-- ================================================================ -->

	<append xpath="//lootgroup[@name='groupWeaponsT0_Ranged']">
		<item group="WakaStarterGuns" loot_prob_template="low"/>
	</append>

	<!-- ================================================================ -->
	<!-- 3. T1-T3: general _Ranged + POI quest reward                    -->
	<!-- T3 は累積経路が多く E[EV] が T4 を超えるため、EFTX T3群のみ     -->
	<!-- veryLow にダウンシフト。IZY孤立2銃は救済目的なので low維持。     -->
	<!-- ================================================================ -->

	<append xpath="//lootgroup[@name='groupWeaponsT1_Ranged']">
		<item group="WakaEFTXGunsT1" loot_prob_template="low"/>
	</append>
	<append xpath="//lootgroup[@name='groupQuestWeaponsRangedT1']">
		<item group="WakaEFTXGunsT1" loot_prob_template="low"/>
	</append>

	<append xpath="//lootgroup[@name='groupWeaponsT2_Ranged']">
		<item group="WakaEFTXGunsT2" loot_prob_template="low"/>
	</append>
	<append xpath="//lootgroup[@name='groupQuestWeaponsRangedT2']">
		<item group="WakaEFTXGunsT2" loot_prob_template="low"/>
	</append>

	<append xpath="//lootgroup[@name='groupWeaponsT3_Ranged']">
		<item group="WakaEFTXGunsT3" loot_prob_template="veryLow"/>
	</append>
	<append xpath="//lootgroup[@name='groupQuestWeaponsRangedT3']">
		<item group="WakaEFTXGunsT3" loot_prob_template="veryLow"/>
	</append>

	<!-- ================================================================ -->
	<!-- 3b. T1-T3 POI Boss Chest (Reinforced_Chest_T[N]): direct inject -->
	<!-- _02 は Weapon OR Armor の二択なので、間接参照(_Ranged経由)だと  -->
	<!-- 確率が希薄になる。ここに直接追加して湧きを安定させる。         -->
	<!-- ================================================================ -->

	<append xpath="//lootgroup[@name='groupReinforcedChestT1_02']">
		<item group="WakaEFTXGunsT1" loot_prob_template="low"/>
	</append>
	<append xpath="//lootgroup[@name='groupReinforcedChestT2_02']">
		<item group="WakaEFTXGunsT2" loot_prob_template="low"/>
	</append>
	<append xpath="//lootgroup[@name='groupReinforcedChestT3_02']">
		<item group="WakaEFTXGunsT3" loot_prob_template="veryLow"/>
	</append>

	<!-- ================================================================ -->
	<!-- 4. T4 HardenedChest: Weapon枠(_04) のみに直接注入 + Bonus(_08)  -->
	<!-- に薄く補充。旧版は _01〜_09 全部に入れて Ammo/Medical 枠からも  -->
	<!-- 銃が出る設計ミスがあり、E[EV/chest] が 9000 超えに膨張していた。 -->
	<!-- 修正後: _04(P≒9%,EV1万) + _08(P≒9.5%,EV1万,count=2) ≒ 1860     -->
	<!-- ================================================================ -->

	<append xpath="//lootgroup[@name='groupHardenedChestT4_04']">
		<item group="WakaEFTXGunsT4" loot_prob_template="low"/>
	</append>
	<append xpath="//lootgroup[@name='groupHardenedChestT4_08']">
		<item group="WakaEFTXGunsT4" loot_prob_template="veryLow"/>
	</append>

	<!-- ================================================================ -->
	<!-- 5. T5 HardenedChest: Weapon枠(_02 count=2) のみ。                -->
	<!-- IZY T5 Heavy 2銃 (AA12, SuperEagle) は同じ _02 に name指定で     -->
	<!-- 直接投入して救済ルートを確保する。                               -->
	<!-- E[EV/chest] ≒ 2 × 0.091 × 15000 ≒ 2730                         -->
	<!-- ================================================================ -->

	<append xpath="//lootgroup[@name='groupHardenedChestT5_02']">
		<item group="WakaEFTXGunsT5" loot_prob_template="low"/>
	</append>

	<!-- ================================================================ -->
	<!-- 6. groupArmyTruck: mid-high tier spread for variety             -->
	<!-- T3/T4 Truck は専用POI限定で希少。ここは変更なし。               -->
	<!-- ================================================================ -->

	<append xpath="//lootgroup[@name='groupArmyTruck03']">
		<item group="WakaEFTXGunsT3" loot_prob_template="veryLow"/>
	</append>
	<append xpath="//lootgroup[@name='groupArmyTruck04']">
		<item group="WakaEFTXGunsT4" loot_prob_template="veryLow"/>
	</append>

</configs>
