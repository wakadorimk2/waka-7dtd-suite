<configs>

	<!-- ================================================================ -->
	<!-- 1. Define Waka lootgroups BEFORE any reference point.            -->
	<!-- 7DTD loot parser registers lootgroups in document order, so a    -->
	<!-- group must appear BEFORE any reference to it. Anchoring at      -->
	<!-- groupWeaponsT0_DeadEye (first weapon-related lootgroup) puts    -->
	<!-- these ahead of every T0-T5 ref site we use below.                -->
	<!-- (source: community.thefunpimps.com thread 34487)                 -->
	<!-- ================================================================ -->

	<insertBefore xpath="//lootgroup[@name='groupWeaponsT0_DeadEye']">

		<!-- T0 starter: hand-picked low-tier firearms (pistols / SMGs /
		     bolt-actions) so the earliest chests can occasionally drop a
		     real gun alongside pipe weapons. -->
