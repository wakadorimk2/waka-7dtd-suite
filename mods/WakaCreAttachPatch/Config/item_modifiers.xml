	<append xpath="/item_modifiers/item_modifier[@name='cre_modArmorFittingsT3']/effect_group[1]">
		<passive_effect name="WalkSpeed" operation="perc_add" value=".06"/>
		<passive_effect name="RunSpeed" operation="perc_add" value=".06"/>
	</append>


