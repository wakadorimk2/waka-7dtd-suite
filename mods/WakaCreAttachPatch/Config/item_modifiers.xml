	</append>

	<!-- cre_modArmorPlating T1-3: BW PlatingBasic pattern - elemental + explosion mitigation. -->
	<append xpath="/item_modifiers/item_modifier[@name='cre_modArmorPlatingT1']/effect_group[1]">
		<passive_effect name="ElementalDamageResist" operation="base_add" value="3" tags="heat,electrical,radiation,toxic"/>
		<passive_effect name="ExplosionIncomingDamage" operation="perc_add" value="-.05"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='cre_modArmorPlatingT2']/effect_group[1]">
		<passive_effect name="ElementalDamageResist" operation="base_add" value="6" tags="heat,electrical,radiation,toxic"/>
		<passive_effect name="ExplosionIncomingDamage" operation="perc_add" value="-.08"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='cre_modArmorPlatingT3']/effect_group[1]">
		<passive_effect name="ElementalDamageResist" operation="base_add" value="10" tags="heat,electrical,radiation,toxic"/>
		<passive_effect name="ExplosionIncomingDamage" operation="perc_add" value="-.12"/>
	</append>

	<!-- cre_modArmorFittings T1-3: BW ImprovedFittings pattern - movement speed bonuses. -->
	<append xpath="/item_modifiers/item_modifier[@name='cre_modArmorFittingsT1']/effect_group[1]">
		<passive_effect name="WalkSpeed" operation="perc_add" value=".02"/>
