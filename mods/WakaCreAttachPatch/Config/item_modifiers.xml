<?xml version="1.0" encoding="UTF-8"?>
<configs>

	<!--
		==========================================================
		Section A: Durability Overhaul integration for Cre_More
		==========================================================
		Cre_More attachments use modCre* / cre_mod* names which fall
		outside Durability Overhaul's starts-with('mod*') XPath net,
		so they never get DegradationTags / DegradationMax / ShowQuality
		out of the box and never break. We wire them up here.
	-->

	<!-- Flip every Cre attachment effect_group to tiered=true so DO can gate them by broken state. -->
	<set xpath="/item_modifiers/item_modifier[starts-with(@name, 'modCre') or starts-with(@name, 'cre_mod')]/effect_group[@tiered='false']/@tiered">true</set>

	<!-- Cre weapon/bow mods (excluding magazines, handled separately). -->
	<append xpath="/item_modifiers/item_modifier[(starts-with(@name, 'modCreGun') or starts-with(@name, 'modCreWeap') or starts-with(@name, 'modCreBow')) and not(contains(@name, 'Magazine'))]">
		<property name="ShowQuality" value="true"/>
		<property name="DegradationTags" value="modGunDegradation"/>
		<property name="DegradationMax" value="300,1100"/>
	</append>

	<!-- Magazine variants get the magazine tag like vanilla MagazineExtender. -->
	<append xpath="/item_modifiers/item_modifier[contains(@name, 'modCreGunMagazine')]">
		<property name="ShowQuality" value="true"/>
		<property name="DegradationTags" value="modGunDegradation,magazine"/>
		<property name="DegradationMax" value="300,1100"/>
	</append>

	<!-- Cre melee mods. -->
	<append xpath="/item_modifiers/item_modifier[starts-with(@name, 'modCreMelee')]">
		<property name="ShowQuality" value="true"/>
		<property name="DegradationTags" value="modMeleeDegradation"/>
		<property name="DegradationMax" value="300,1100"/>
	</append>

	<!-- Cre armor plating tracks vanilla modArmorPlating treatment. -->
	<append xpath="/item_modifiers/item_modifier[starts-with(@name, 'cre_modArmorPlating')]">
		<property name="ShowQuality" value="true"/>
		<property name="DegradationMax" value="300,1100"/>
	</append>


	<!--
		==========================================================
		Section B: Black Wolf style conditional bonuses
		==========================================================
		Cre's flat values are already strong, so we don't bump them.
		Instead we add conditional/situational layers that mirror BW's
		design (head bonus, long-range bonus, dismember chance, etc.).
	-->

	<!-- modCreWeapDamage T1-3: headshot bonus damage on top of the flat EntityDamage. -->
	<append xpath="/item_modifiers/item_modifier[@name='modCreWeapDamageT1']/effect_group[1]">
		<passive_effect name="EntityDamage" operation="perc_add" value=".15">
			<requirement name="HitLocation" body_parts="Head"/>
		</passive_effect>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreWeapDamageT2']/effect_group[1]">
		<passive_effect name="EntityDamage" operation="perc_add" value=".3">
			<requirement name="HitLocation" body_parts="Head"/>
		</passive_effect>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreWeapDamageT3']/effect_group[1]">
		<passive_effect name="EntityDamage" operation="perc_add" value=".55">
			<requirement name="HitLocation" body_parts="Head"/>
		</passive_effect>
	</append>

	<!-- modCreGunRPM T1-3: faster fire rate compounds into less spread per shot. -->
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunRPMT1']/effect_group[1]">
		<passive_effect name="IncrementalSpreadMultiplier" operation="perc_add" value="-.05"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunRPMT2']/effect_group[1]">
		<passive_effect name="IncrementalSpreadMultiplier" operation="perc_add" value="-.1"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunRPMT3']/effect_group[1]">
		<passive_effect name="IncrementalSpreadMultiplier" operation="perc_add" value="-.2"/>
	</append>

	<!-- modCreGunReload T1-3: small RoundsPerMinute uplift, like BW MagazineExtender. -->
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunReloadT1']/effect_group[1]">
		<passive_effect name="RoundsPerMinute" operation="perc_add" value=".05"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunReloadT2']/effect_group[1]">
		<passive_effect name="RoundsPerMinute" operation="perc_add" value=".1"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunReloadT3']/effect_group[1]">
		<passive_effect name="RoundsPerMinute" operation="perc_add" value=".15"/>
	</append>

	<!-- modCreGunGrip T1-3: also grants WeaponHandling, like BW Bipod/Forgrip. -->
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunGripT1']/effect_group[1]">
		<passive_effect name="WeaponHandling" operation="perc_add" value=".1"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunGripT2']/effect_group[1]">
		<passive_effect name="WeaponHandling" operation="perc_add" value=".2"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunGripT3']/effect_group[1]">
		<passive_effect name="WeaponHandling" operation="perc_add" value=".3"/>
	</append>

	<!-- modCreGunRange T1-3: extra damage at long range (BW BarrelExtender pattern). -->
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunRangeT1']/effect_group[1]">
		<passive_effect name="EntityDamage" operation="perc_add" value=".25">
			<requirement name="TargetRange" target="other" operation="GTE" value="40"/>
		</passive_effect>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunRangeT2']/effect_group[1]">
		<passive_effect name="EntityDamage" operation="perc_add" value=".5">
			<requirement name="TargetRange" target="other" operation="GTE" value="40"/>
		</passive_effect>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunRangeT3']/effect_group[1]">
		<passive_effect name="EntityDamage" operation="perc_add" value="1">
			<requirement name="TargetRange" target="other" operation="GTE" value="40"/>
		</passive_effect>
	</append>

	<!-- modCreGunSniper T1-3: head dismember chance + extra headshot bonus, like BW ScopeLarge. -->
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT1']/effect_group[1]">
		<passive_effect name="EntityDamage" operation="perc_add" value=".25">
			<requirement name="HitLocation" body_parts="Head"/>
		</passive_effect>
		<passive_effect name="DismemberChance" operation="base_add" value=".15">
			<requirement name="HitLocation" body_parts="Head"/>
		</passive_effect>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT2']/effect_group[1]">
		<passive_effect name="EntityDamage" operation="perc_add" value=".5">
			<requirement name="HitLocation" body_parts="Head"/>
		</passive_effect>
		<passive_effect name="DismemberChance" operation="base_add" value=".3">
			<requirement name="HitLocation" body_parts="Head"/>
		</passive_effect>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT3']/effect_group[1]">
		<passive_effect name="EntityDamage" operation="perc_add" value=".9">
			<requirement name="HitLocation" body_parts="Head"/>
		</passive_effect>
		<passive_effect name="DismemberChance" operation="base_add" value=".6">
			<requirement name="HitLocation" body_parts="Head"/>
		</passive_effect>
	</append>

	<!-- modCreMeleeAPM T1-3: faster swings cost less stamina (BW ErgonomicGrip pattern). -->
	<append xpath="/item_modifiers/item_modifier[@name='modCreMeleeAPMT1']/effect_group[1]">
		<passive_effect name="StaminaLoss" operation="perc_add" value="-.1" tags="primary,secondary"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreMeleeAPMT2']/effect_group[1]">
		<passive_effect name="StaminaLoss" operation="perc_add" value="-.18" tags="primary,secondary"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreMeleeAPMT3']/effect_group[1]">
		<passive_effect name="StaminaLoss" operation="perc_add" value="-.28" tags="primary,secondary"/>
	</append>

	<!-- modCreMeleeBlock T1-3: dismember chance on hit (carries the heavy block forward). -->
	<append xpath="/item_modifiers/item_modifier[@name='modCreMeleeBlockT1']/effect_group[1]">
		<passive_effect name="DismemberChance" operation="base_add" value=".05"/>
	</append>
	<append xpath="/item_modifiers/item_modifier[@name='modCreMeleeBlockT2']/effect_group[1]">
