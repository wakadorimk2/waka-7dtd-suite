<configs>
	<append xpath="/nav_object_classes">
		<nav_object_class name="waka_beacon">
			<map_settings>
				<property name="sprite_name" value="ui_game_symbol_electric_generator"/>
				<property name="min_distance" value="0"/>
				<property name="max_distance" value="-1"/>
				<property name="color" value="0,200,255,255"/>
				<property name="has_pulse" value="true"/>
				<property name="adjust_center" value="true"/>
			</map_settings>
			<compass_settings>
				<property name="sprite_name" value="ui_game_symbol_electric_generator"/>
				<property name="up_sprite_name" value="ui_game_symbol_electric_generator_up"/>
				<property name="down_sprite_name" value="ui_game_symbol_electric_generator_down"/>
				<property name="min_distance" value="0"/>
				<property name="max_distance" value="1024"/>
				<property name="max_scale_distance" value="128"/>
				<property name="color" value="0,200,255,255"/>
				<property name="has_pulse" value="true"/>
				<property name="icon_clamped" value="false"/>
			</compass_settings>
			<onscreen_settings>
				<property name="sprite_name" value="ui_game_symbol_electric_generator"/>
				<property name="min_distance" value="2"/>
				<property name="max_distance" value="128"/>
				<property name="color" value="0,200,255,255"/>
				<property name="has_pulse" value="true"/>
				<property name="text_type" value="Name"/>
				<property name="offset" value="0.5,0.8,0.5"/>
			</onscreen_settings>
		</nav_object_class>
	</append>
</configs>
