	<!-- ==================== IZY advance gun repair kit ==================== -->
	<!-- EV=5000 は T3銃の売値並み。EV=1000 に減額 + Stack=5 + 売却不可。   -->
	<set xpath="//item[@name='IZYadvancegunrepairkit']/property[@name='EconomicValue']/@value">1000</set>
