	<!-- ================================================================ -->
	<!-- 柱2: 修理キット搾取経路の遮断                                     -->
	<!-- EFTXの6種は EV=400・Stack=25 で1スタック=10kEV→売値30k coins     -->
	<!-- IZY advance kit は EV=5000・Stack=25 で1スタック125kEV→375k coins -->
	<!-- Stack を 25→5 に絞り、SellableToTrader=false で売却完全遮断       -->
	<!-- ================================================================ -->

	<!-- ==================== EFTX 修理キット 6種 ==================== -->
	<set xpath="//item[@name='resourceLauncherRepairKit']/property[@name='Stacknumber']/@value">5</set>
	<append xpath="//item[@name='resourceLauncherRepairKit']">
		<property name="SellableToTrader" value="false"/>
	</append>

	<set xpath="//item[@name='resourceMachineGunRepairKit']/property[@name='Stacknumber']/@value">5</set>
