<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Waka Pet v0.1 - npc

  新 faction "wakaPet" を定義。すべての他 faction とは neutral 関係。
  これでプレイヤーが攻撃対象に取られない（ペット側もプレイヤーを敵視しない）。

  vanilla の npc.xml の <factions> セクションに append する。
-->
<configs>
    <append xpath="/npc/factions">
        <faction name="wakaPet">
            <relationship name="*" value="neutral"/>
        </faction>
    </append>
</configs>
