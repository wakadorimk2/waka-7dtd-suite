<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Waka Pet v0.1 - buffs

  buffWakaPetImmortal:
    Waka Pet entity の完全無敵化 buff。誤クリック・誤発砲で消えないようにする。
    vanilla の god mode buff (buffs.xml:46-) と同じ GeneralDamageResist 1.0 パターン。
    GeneralDamageResist=1.0 で全ダメージ (物理 + 元素) を 100% 吸収。
    hidden=true で UI 非表示、remove_on_death=false で永続、duration=0 で恒久。
-->
<configs>
    <append xpath="/buffs">
        <buff name="buffWakaPetImmortal" hidden="true" remove_on_death="false">
            <stack_type value="ignore"/>
            <duration value="0"/>
            <effect_group name="WakaPet Immortal Effects">
                <passive_effect name="GeneralDamageResist" operation="base_add" value="1"/>
            </effect_group>
        </buff>
    </append>
</configs>
