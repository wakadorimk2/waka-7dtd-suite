<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Waka Pet v0.7.0 - entityclasses (Rocky procedural locomotion 版)

  v0.6 から継続して Rocky mesh を使用。bone は articfox_*_bone 命名（Tripo rig をリネーム済み）。
  違い：
  - Walk アニメは捨てて Idle 1 状態に縮約（Animator は呼吸のみ駆動）
  - 4脚 procedural 回転 (forward kinematics) + bound/wave gait + 体動は Source/Harmony/ProceduralLocomotion.cs で C# 側実装
  - 注: 真の IK は未実装、Question? motion で足先 world 固定が必要なら別途追加
  - 上向き肢（Tail 系 bone）は「掲げ手」として rest pose 維持（原作リスペクト）
-->
<configs>
    <append xpath="/entity_classes">
        <entity_class name="entityWakaPetRabbit" extends="npcAnimalMeleeTemplate">
            <property name="UserSpawnType" value="Menu"/>
            <property name="Tags" value="entity,animal,npc,wakaPet"/>
            <property name="EntityFlags" value="animal"/>

            <!-- ペット用 faction (npc.xml で定義済み、全関係 neutral) -->
            <property name="Faction" value="wakaPet"/>

            <!-- Rocky rigged Mesh -->
            <property name="Mesh" value="#@modfolder:Resources/wakapet_rocky.unity3d?Rocky.Prefab"/>

            <!-- AvatarController は npcAnimalMeleeTemplate の AvatarAnimalController を継承 -->
            <!-- bone 名は articfox 互換、procedural 上書きは LateUpdate Postfix で後段に重ねる -->

            <!-- root motion 抑制 -->
            <property name="RootMotion" value="false"/>

            <!-- vanilla の中型動物 physics body -->
            <property name="PhysicsBody" value="Doe"/>

            <!-- Blender で 2m サイズ + 底面 Pivot 設計、3m 目標で 1.5x -->
            <property name="SizeScale" value="1.5"/>

            <!-- 移動速度：template の .3/1.5 は早すぎ、半分に -->
            <property name="MoveSpeed" value="0.15"/>
            <property name="MoveSpeedAggro" value="0.8, 0.8"/>
            <property name="MoveSpeedPanic" value="0.8"/>

            <!-- 表示アイコン -->
            <property name="MapIcon" value="ui_game_symbol_tracking_rabbit"/>
            <property name="TrackerIcon" value="ui_game_symbol_tracking_rabbit"/>

            <!-- 攻撃しない -->
            <property name="HandItem" value=""/>

            <!-- AI: Look + Wander のみ、攻撃ターゲット取らない -->
            <property name="AITask" value="
                Look|
                Wander|
            "/>
            <property name="AITarget" value=""/>

            <!-- 完全無敵 buff -->
            <effect_group name="WakaPet Init">
                <triggered_effect trigger="onSelfFirstSpawn" action="AddBuff" buff="buffWakaPetImmortal"/>
                <triggered_effect trigger="onSelfEnteredGame" action="AddBuff" buff="buffWakaPetImmortal"/>
            </effect_group>
        </entity_class>

        <!--
          v0.8 caged 派生 (Faraday cage 内で眠る初邂逅形態)

          世界観：映画/原作『プロジェクト・ヘイル・メアリー』のロッキーが Faraday cage 内で
          冬眠状態にあり、後から到達したサバイバーが "発見する" 形態。

          設計：
          - entityWakaPetRabbit を継承（mesh, faction, EntityFlags=animal は引き継ぎ）
          - EntityFlags=animal が ClearSleepers の scoring 対象外を担保（NPCCore明示）
          - 完全静止：移動 0、AI は Look のみ（視線追従のみ残して "気配" 演出）
          - sleeperVolume 経由で全POIに低確率混入される（entitygroups.xml 参照）
          - 撫で（dialog open）時に Source/Harmony/QuestionDialogHook.cs が
            destroy → entityWakaPetRabbit に置換して "起動" 演出
        -->
        <entity_class name="entityWakaPetRabbit_caged" extends="entityWakaPetRabbit">
            <!--
              重要: caged は最初から "awake" 状態として spawn する.
              vanilla zombie sleeper と同じ AI フロー (Look|Wander|) に乗せないと、
              sleeper system が「pending sleeper, slot補充必要」判定で
              "Restoring" を連続発火する.

              wander する眠れる存在 = Tau Ceti で活動中のロッキーが地球の世界に居る、
              というシンプルな canon 翻訳.
            -->
            <property name="MoveSpeed" value="0.10"/>
            <property name="MoveSpeedAggro" value="0.10,0.10"/>
            <property name="MoveSpeedPanic" value="0.15"/>

            <property name="AITask" value="Look|Wander|"/>
            <property name="AITarget" value=""/>

            <!-- マップ非表示（"発見する"演出のため） -->
            <property name="MapIcon" value=""/>
            <property name="TrackerIcon" value=""/>
            <property name="CompassIcon" value=""/>

            <!-- 確実に awake state で spawn（sleeper Restoring 抑止） -->
            <property name="SleeperInstantAwake" value="true"/>

            <!--
              attack 系を完全無効化:
              親 npcAnimalMeleeTemplate から meleeHandAnimalCoyote を継承するため、
              hire後に UAI が AttackTargetEntitySDX を試行 → AvatarAnimalController.IsAnimationAttackPlaying で
              NullReferenceException 発生.
              HandItem 空 + 攻撃関連 sound 全て空にして、wolf の attack animation が呼ばれないようにする.
            -->
            <property name="HandItem" value=""/>

            <!-- 犬声を全部消す: vanilla wolf 系 sound (wolfroam/wolfalert/wolfattack 等) を上書き -->
            <property name="SoundRandom" value=""/>
            <property name="SoundAlert" value=""/>
            <property name="SoundHurt" value=""/>
            <property name="SoundHurtSmall" value=""/>
            <property name="SoundDeath" value=""/>
            <property name="SoundAttack" value=""/>
            <property name="SoundSense" value=""/>
            <property name="SoundGiveUp" value=""/>

            <!-- 雇用設定: 肉20個 → エリディアン技術ぽい electricParts 3個 -->
            <property name="HireCurrency" value="resourceElectricParts"/>
            <property name="HireCost" value="3"/>

            <!-- ロッキー語彙の名前 (映画/原作の特徴的な単語) -->
            <property name="Names" value="Rocky, Brother, Question, Friend, Amaze"/>

            <!--
              attack NRE 回避は Harmony patch (Source/Harmony/AvatarAnimalAttackBypass.cs) で実装.
              buffNPCModStopAttacking 付与は move action 含めて全停止しちゃうため不採用.
            -->

            <!--
              v0.9: caged は野生 wildlife として死亡可能にする (POI 退避、Aルート).
              親 entityWakaPetRabbit の WakaPet Init で AddBuff された buffWakaPetImmortal を
              spawn 直後に RemoveBuff で剥がす。
              hired form (entityWakaPetRabbit base) は引き続き不死 (companion 保護) 。
            -->
            <effect_group name="WakaPet Caged Mortal Override">
                <triggered_effect trigger="onSelfFirstSpawn" action="RemoveBuff" buff="buffWakaPetImmortal"/>
                <triggered_effect trigger="onSelfEnteredGame" action="RemoveBuff" buff="buffWakaPetImmortal"/>
            </effect_group>
        </entity_class>
    </append>
</configs>
