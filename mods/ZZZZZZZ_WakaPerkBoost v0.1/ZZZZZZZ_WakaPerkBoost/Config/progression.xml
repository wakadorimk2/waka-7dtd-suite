<configs>

<!--
========================================================================
  Waka Perk Boost v0.5 - progression.xml
  Role: Bridge between BlackWolf / Bloodfall / Mickkpewpews LbD / CLBM.
  Loads AFTER all of them.

  v0.5 (current): vanilla-side @value を v0.3 値に完全復元。
    Day9 OP感への対処は WakaSlowCurve の PlayerExpGain 抑制側で行う
    (v0.5.1 で -.15 → -.50 強化、進行ペースを半分に)。

  v0.6 attempt (撤回 2026-05-11): Mining/Salvage 10段化試作したが、
    Localization desc 整備の重さで「遊べる状態」じゃなくなり撤回。
    代わりに WakaSlowCurve の PlayerExpGain 抑制強化路線に移行。
    10段化路線は将来再挑戦の可能性あり (memory に技術知見保存済)。

  v0.5 history: vanilla-side @value scales を v0.3 値に完全復元
    (v0.4 halve は破綻パターンと記録済み)。

  v0.4 history: vanilla-side @value scales をすべて 50% halve、結果は
    「nerf しすぎ」で v0.3 復元。

  v0.3 history: Removed 10 ZV perks that pure-duplicate BlackWolf
  (PackMule, Miner69r, LuckyLooter, etc). Kept ZV damage / HP / regen /
  resist multipliers as the player-side answer to Bloodfall HP-2300+
  zombies. Mickkpewpews LbD only feeds craftingSkill (=magazine read),
  so ZV damage multipliers don't double-stack with Mickk.
========================================================================
-->

<!-- ============================================================
     SECTION 1: Remove ONLY pure BlackWolf duplicates
     ============================================================ -->

<!-- Strength tree -->
<remove xpath="/progression/perks/perk[@name='perkZVIronBack']"/>          <!-- = perkPackMule -->
<remove xpath="/progression/perks/perk[@name='perkStrengthHammerStamina']"/> <!-- generic stamina, BW Cardio/Mickk -->
<remove xpath="/progression/perks/perk[@name='perkZVMasterMiner']"/>       <!-- = perkMiner69r -->

<!-- Perception tree -->
<remove xpath="/progression/perks/perk[@name='perkZVScavenger']"/>         <!-- = perkLuckyLooter LootStage -->
<remove xpath="/progression/perks/perk[@name='perkPerceptionSpearRange']"/> <!-- = perkJavelinMaster MaxRange -->
<remove xpath="/progression/perks/perk[@name='perkZVLuckyEye']"/>          <!-- = perkLuckyLooter ScavengingTime -->
<remove xpath="/progression/perks/perk[@name='perkZVArmorPenetration']"/>  <!-- = perkPenetrator -->

<!-- Fortitude tree -->
<remove xpath="/progression/perks/perk[@name='perkZVIronStomach']"/>       <!-- = perkSlowMetabolism -->

<!-- Agility tree -->
<remove xpath="/progression/perks/perk[@name='perkZVFleetFooted']"/>       <!-- = perkRuleOneCardio RunSpeed -->
<remove xpath="/progression/perks/perk[@name='perkZVEndurance']"/>         <!-- = generic AttacksPerMinute (BW per-weapon) -->


