<?xml version="1.0" encoding="utf-8"?>
<configs>

<!--
========================================================================
  Waka Slow Curve v0.1 - traders.xml
  Vanilla formula:  Trader Stage = Player Level * (1 + quest_tier_mod)
  XP brake -0.15 already gives 0.85x trader stage as a cascade.
  Earlier versions used a broad 1.21x trader threshold pass. The hot path
  below now uses explicit quality-by-quality pacing so baseTier2 starts
  around the second week and higher qualities resolve gradually instead of
  collapsing into a single unlock stage.

  Legacy multiplier table (rounded) still applies to supporting tiers:
      5 -> 6     30 -> 36    65 -> 79     100 -> 121
     10 -> 12    35 -> 42    70 -> 85     150 -> 182
     15 -> 18    40 -> 48    75 -> 91
     20 -> 24    45 -> 54    80 -> 97
     25 -> 30    50 -> 61    85 -> 103
                 55 -> 67    90 -> 109
                 60 -> 73    95 -> 115

  @min values of 1 are kept (always-available), 999999 entries are
  kept (never-show), only the meaningful gating values are scaled.
========================================================================
-->


<!-- ============================================================
     baseTier0 (Stone Tools | Pipe Weapons | Utility Tools)
     ============================================================ -->
<set xpath="/traders/traderstage_templates/traderstage_template[@name='baseTier0']/entry[@quality='2']/@min">1</set>
<set xpath="/traders/traderstage_templates/traderstage_template[@name='baseTier0']/entry[@quality='3']/@min">6</set>
<set xpath="/traders/traderstage_templates/traderstage_template[@name='baseTier0']/entry[@quality='4']/@min">12</set>
<set xpath="/traders/traderstage_templates/traderstage_template[@name='baseTier0']/entry[@quality='5']/@min">18</set>


