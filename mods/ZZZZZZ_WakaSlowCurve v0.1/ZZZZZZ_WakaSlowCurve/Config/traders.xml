<set xpath="/traders/traderstage_templates/traderstage_template[@name='baseTier1']/entry[@quality='3']/@min">48</set>
<set xpath="/traders/traderstage_templates/traderstage_template[@name='baseTier1']/entry[@quality='4']/@min">61</set>
<set xpath="/traders/traderstage_templates/traderstage_template[@name='baseTier1']/entry[@quality='5']/@min">73</set>


