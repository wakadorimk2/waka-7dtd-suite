<?xml version="1.0" encoding="UTF-8"?>
<configs>

  <!-- Candidate C: keep Slayer AP rewards as prep bundles, not a sustain source. -->
  <set xpath="//quest[starts-with(@id, 'waka_zs_quest_')]/reward[@type='Item' and @id='ammoEftAP20Slug']/@value">20</set>
  <set xpath="//quest[starts-with(@id, 'waka_zs_quest_')]/reward[@type='Item' and @id='ammoJunkTurretAP']/@value">80</set>

  <!-- v0.2: Slayer rewards can seed specialty ammo, not feed it forever. -->
  <set xpath="//quest[starts-with(@id, 'waka_zs_quest_')]/reward[@type='Item' and (contains(@id,'BulletAP') or contains(@id,'Armor') or contains(@id,'Eft') and contains(@id,'AP') or @id='ammoJunkTurretAP')]/@value">25</set>
  <set xpath="//quest[starts-with(@id, 'waka_zs_quest_')]/reward[@type='Item' and (contains(@id,'Slug') or contains(@id,'Flechette') or contains(@id,'Shrapnel'))]/@value">16</set>
  <set xpath="//quest[starts-with(@id, 'waka_zs_quest_')]/reward[@type='Item' and (@id='thrownGrenade' or @id='thrownGrenadeContact' or @id='thrownAmmoPipeBomb' or @id='thrownDynamite' or @id='thrownTimedCharge')]/@value">3</set>

</configs>
