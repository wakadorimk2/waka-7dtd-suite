<?xml version="1.0" encoding="UTF-8"?>
<configs>

  <!-- Candidate C: make AP slug press output feel like specialty prep, not baseline shotgun ammo. -->
  <set xpath="//recipe[@name='ammoEftAP20Slug' and @craft_area='ammopress']/ingredient[@name='resourceScrapLead']/@count">30</set>
  <set xpath="//recipe[@name='ammoEftAP20Slug' and @craft_area='ammopress']/ingredient[@name='resource_item_other_powder_red']/@count">32</set>
  <append xpath="//recipe[@name='ammoEftAP20Slug' and @craft_area='ammopress']">
    <ingredient name="resourceForgedSteel" count="1"/>
  </append>

  <set xpath="//recipe[@name='ammoEftBarricadeSlug' and @craft_area='ammopress']/ingredient[@name='resourceScrapLead']/@count">35</set>
  <set xpath="//recipe[@name='ammoEftBarricadeSlug' and @craft_area='ammopress']/ingredient[@name='resource_item_other_powder_red']/@count">36</set>
  <append xpath="//recipe[@name='ammoEftBarricadeSlug' and @craft_area='ammopress']">
    <ingredient name="resourceForgedSteel" count="1"/>
  </append>

  <!-- v0.2 Ammo Press: HP costs more than ball, AP/slug/explosive costs much more. -->
  <set xpath="//recipe[@craft_area='ammopress' and (contains(@name,'HP') or contains(@name,'HIpower') or contains(@name,'Highpower') or contains(@name,'RIP'))]/ingredient[@name='resource_item_other_powder_red']/@count">20</set>
  <set xpath="//recipe[@craft_area='ammopress' and (contains(@name,'AP') or contains(@name,'Armor'))]/ingredient[@name='resourceScrapLead']/@count">24</set>
  <set xpath="//recipe[@craft_area='ammopress' and (contains(@name,'AP') or contains(@name,'Armor'))]/ingredient[@name='resource_item_other_powder_red']/@count">26</set>
  <set xpath="//recipe[@craft_area='ammopress' and contains(@name,'Slug')]/ingredient[@name='resourceScrapLead']/@count">30</set>
  <set xpath="//recipe[@craft_area='ammopress' and contains(@name,'Slug')]/ingredient[@name='resource_item_other_powder_red']/@count">32</set>

  <append xpath="//recipe[@name='ammo762mmBulletAP' and @craft_area='ammopress']">
    <ingredient name="resourceForgedSteel" count="2"/>
  </append>
  <append xpath="//recipe[@name='ammo556mmArmorPiercing' and @craft_area='ammopress']">
    <ingredient name="resourceForgedSteel" count="2"/>
  </append>
  <append xpath="//recipe[@name='ammo45ACPArmorpiecing' and @craft_area='ammopress']">
    <ingredient name="resourceForgedSteel" count="1"/>
  </append>
  <append xpath="//recipe[@name='ammoRocketRPGHE' and @craft_area='ammopress']">
    <ingredient name="resourceForgedSteel" count="4"/>
  </append>

  <!-- v0.2 recycling: non-ball ammo needs more input per bundle, lowering return rate. -->
  <set xpath="//recipe[starts-with(@name,'recycledAmmoSonja') and (contains(@name,'HP') or contains(@name,'Highpower') or contains(@name,'RIP'))]/ingredient/@count">170</set>
  <set xpath="//recipe[starts-with(@name,'recycledAmmoSonja') and (contains(@name,'AP') or contains(@name,'Armor') or contains(@name,'Slug') or contains(@name,'Flechette') or contains(@name,'Shrapnel'))]/ingredient/@count">220</set>
  <set xpath="//recipe[starts-with(@name,'recycledAmmoSonja') and (contains(@name,'Rocket') or contains(@name,'RPG') or contains(@name,'Grenade') or contains(@name,'Explosive') or contains(@name,'thrown'))]/ingredient/@count">285</set>

</configs>
