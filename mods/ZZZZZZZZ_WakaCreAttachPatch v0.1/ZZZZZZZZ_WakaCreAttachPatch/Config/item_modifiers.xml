<?xml version="1.0" encoding="UTF-8"?>
<configs>

	<!--
		==========================================================
		v0.5 — Hybrid (Base + Delta) for panel-friendly stat display
		==========================================================
		v0.4 used SCore ItemHasQuality multi-group for q-band scaling.
		Verified working in actual gameplay (Mag Size q1=33→q4=39), but
		the workbench Modify panel preview *doesn't* fire requirement-
		gated effect_groups (plate showed Armor Rating 0 at q3).

		v0.5 hybrid structure:
		    Base group (no requirement) = T2 mid value → panel sees this
		    q1-q2 group (LTE 2)         = (T1 - T2) negative delta
		    q5-q6 group (GTE 5)         = (T3 - T2) positive delta
		                                  + BW conditional bonuses

		Result:
		    Panel preview: base (T2 mid) value visible at all qualities
		    Actual gameplay: q1=T1, q3-q4=T2, q5-q6=T3 with BW bonuses
		    Player sees a "guideline" number; description hints scaling
	-->


	<!--
		==========================================================
		Section A: Durability Overhaul integration (T1 only)
		==========================================================
	-->

	<set xpath="/item_modifiers/item_modifier[(starts-with(@name, 'modCre') or starts-with(@name, 'cre_mod')) and contains(@name, 'T1')]/effect_group[@tiered='false']/@tiered">true</set>

	<append xpath="/item_modifiers/item_modifier[(starts-with(@name, 'modCreGun') or starts-with(@name, 'modCreWeap') or starts-with(@name, 'modCreBow')) and contains(@name, 'T1') and not(contains(@name, 'Magazine'))]">
		<property name="ShowQuality" value="true"/>
		<property name="DegradationTags" value="modGunDegradation"/>
		<property name="DegradationMax" value="300,1100"/>
	</append>

	<append xpath="/item_modifiers/item_modifier[contains(@name, 'modCreGunMagazine') and contains(@name, 'T1')]">
		<property name="ShowQuality" value="true"/>
		<property name="DegradationTags" value="modGunDegradation,magazine"/>
		<property name="DegradationMax" value="300,1100"/>
	</append>

	<append xpath="/item_modifiers/item_modifier[starts-with(@name, 'modCreMelee') and contains(@name, 'T1')]">
		<property name="ShowQuality" value="true"/>
		<property name="DegradationTags" value="modMeleeDegradation"/>
		<property name="DegradationMax" value="300,1100"/>
	</append>

	<append xpath="/item_modifiers/item_modifier[starts-with(@name, 'cre_modArmorPlating') and contains(@name, 'T1')]">
		<property name="ShowQuality" value="true"/>
		<property name="DegradationMax" value="300,1100"/>
	</append>


	<!--
		==========================================================
		Section D1: Make Cre T1 items quality-aware (Quality=6)
		==========================================================
	-->

	<append xpath="/item_modifiers/item_modifier[(starts-with(@name, 'modCre') or starts-with(@name, 'cre_mod')) and contains(@name, 'T1')]">
		<property name="Quality" value="6"/>
	</append>


	<!--
		==========================================================
		Section D2: Set Cre T1 base passive_effects to T2 mid value
		(panel sees this since base group has no requirement)
		==========================================================
	-->

	<!-- Weapon-side base value substitutions -->
	<set xpath="/item_modifiers/item_modifier[@name='modCreWeapDamageT1']/effect_group/passive_effect[@name='EntityDamage']/@value">.20</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreWeapDurabT1']/effect_group/passive_effect[@name='DegradationPerUse']/@value">-.25</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunRPMT1']/effect_group/passive_effect[@name='RoundsPerMinute']/@value">.25</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunReloadT1']/effect_group/passive_effect[@name='ReloadSpeedMultiplier']/@value">.35</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunMagazineT1']/effect_group/passive_effect[@name='MagazineSize']/@value">.75</set>

	<!-- Grip multi-effect -->
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunGripT1']/effect_group/passive_effect[@name='SpreadMultiplierCrouching']/@value">-.30</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunGripT1']/effect_group/passive_effect[@name='SpreadMultiplierHip']/@value">-.25</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunGripT1']/effect_group/passive_effect[@name='SpreadMultiplierWalking']/@value">-.20</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunGripT1']/effect_group/passive_effect[@name='KickDegreesVerticalMin']/@value">-.65</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunGripT1']/effect_group/passive_effect[@name='KickDegreesVerticalMax']/@value">-.65</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunGripT1']/effect_group/passive_effect[@name='KickDegreesHorizontalMin']/@value">-.65</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunGripT1']/effect_group/passive_effect[@name='KickDegreesHorizontalMax']/@value">-.65</set>

	<!-- Range -->
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunRangeT1']/effect_group/passive_effect[@name='DamageFalloffRange']/@value">.25</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunRangeT1']/effect_group/passive_effect[@name='MaxRange']/@value">.25</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunRangeT1']/effect_group/passive_effect[@name='WeaponHandling']/@value">.25</set>

	<!-- Sniper heavy multi-effect -->
