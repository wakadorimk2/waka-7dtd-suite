	<set xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT1']/effect_group/passive_effect[@name='DamageFalloffRange']/@value">.40</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT1']/effect_group/passive_effect[@name='MaxRange']/@value">.40</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT1']/effect_group/passive_effect[@name='WeaponHandling' and not(requirement)]/@value">-.65</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT1']/effect_group/passive_effect[@name='WeaponHandling' and requirement[@name='HasBuff']]/@value">1.25</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT1']/effect_group/passive_effect[@name='SpreadMultiplierHip']/@value">1.15</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT1']/effect_group/passive_effect[@name='SpreadMultiplierAiming']/@value">-.35</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT1']/effect_group/passive_effect[@name='SpreadMultiplierCrouching']/@value">1.15</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunSniperT1']/effect_group/passive_effect[@name='SpreadMultiplierWalking']/@value">1.15</set>

	<!-- OneB (only EntityDamage scales; others static) -->
	<set xpath="/item_modifiers/item_modifier[@name='modCreGunOneBT1']/effect_group/passive_effect[@name='EntityDamage']/@value">.90</set>

	<!-- BowString -->
	<set xpath="/item_modifiers/item_modifier[@name='modCreBowStringT1']/effect_group/passive_effect[@name='ProjectileVelocity']/@value">.25</set>

	<!-- BowPower -->
	<set xpath="/item_modifiers/item_modifier[@name='modCreBowPowerT1']/effect_group/passive_effect[@name='EntityDamage']/@value">.20</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreBowPowerT1']/effect_group/passive_effect[@name='WeaponHandling']/@value">.25</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreBowPowerT1']/effect_group/passive_effect[@name='DamageFalloffRange']/@value">.25</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreBowPowerT1']/effect_group/passive_effect[@name='MaxRange']/@value">.25</set>

	<!-- Melee -->
	<set xpath="/item_modifiers/item_modifier[@name='modCreMeleeAPMT1']/effect_group/passive_effect[@name='AttacksPerMinute']/@value">.35</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreMeleeStaminaT1']/effect_group/passive_effect[@name='StaminaLoss']/@value">-.20</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreMeleeRangeT1']/effect_group/passive_effect[@name='MaxRange']/@value">.55</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreMeleeRangeT1']/effect_group/passive_effect[@name='BlockRange']/@value">.55</set>
	<set xpath="/item_modifiers/item_modifier[@name='modCreMeleeBlockT1']/effect_group/passive_effect[@name='BlockDamage']/@value">.25</set>

	<!-- Armor -->
