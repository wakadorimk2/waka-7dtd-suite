	<set xpath="/item_modifiers/item_modifier[@name='cre_modArmorFittingsT1']/effect_group/passive_effect[@name='StaminaChangeOT' and @tags='walking']/@value">.019</set>
	<set xpath="/item_modifiers/item_modifier[@name='cre_modArmorFittingsT1']/effect_group/passive_effect[@name='StaminaChangeOT' and @tags='running']/@value">.051</set>
	<set xpath="/item_modifiers/item_modifier[@name='cre_modArmorPlatingT1']/effect_group/passive_effect[@name='PhysicalDamageResist']/@value">1.75</set>
	<set xpath="/item_modifiers/item_modifier[@name='cre_modArmorBootsStorageT1']/effect_group/passive_effect[@name='CarryCapacity']/@value">6</set>
	<set xpath="/item_modifiers/item_modifier[@name='cre_modArmorHealthT1']/effect_group/passive_effect[@name='HealthMax']/@value">10</set>
	<set xpath="/item_modifiers/item_modifier[@name='cre_modArmorStaminaT1']/effect_group/passive_effect[@name='StaminaMax']/@value">10</set>


