<?xml version="1.0" encoding="UTF-8"?>
<configs>

	<!--
		==========================================================
		v0.4 — Magazine learning (crafting_skill) integration
		==========================================================
		v0.3 used skill-point perks to gate Cre recipes. わかどりちゃん
		希望: vanilla Crafting panel (N key) で「Auto Weapons 23/100」式
		の magazine-learning system に乗せ替え。

		Each Cre attachment is bound to one of the vanilla crafting_skills
		via RecipeTagUnlocked + CraftingTier base_add. Recipe unlocks at
		skill level 1; quality output scales tier 0→5 (= q1→q6) over the
		skill's max_level range. Pattern matches vanilla pickaxe entry
		in /Data/Config/progression.xml craftingHarvestingTools block.

		Distribution (36 attachments → 10 crafting_skills):
			craftingRepairTools (max 50)    2  WeapDamage, WeapDurab
			craftingBlades (max 75)         2  MeleeFire, MeleeShock
			craftingClubs (max 75)          3  MeleeAPM, MeleeRange, MeleeStamina
			craftingSledgehammers (max 75)  2  MeleeBlock, MeleeBreak
			craftingBows (max 75)           2  BowString, BowPower
			craftingHandguns (max 100)      3  GunReload, GunGrip, GunShock
			craftingShotguns (max 100)      1  GunOneB
			craftingRifles (max 100)        3  GunSniper, GunRange, GunBlood
			craftingMachineGuns (max 100)   2  GunRPM, GunMagazine
			craftingArmor (max 100)         16 all cre_modArmor*
	-->


	<!-- ===== craftingRepairTools (max 50): Damage core, Durability core ===== -->
	<append xpath="//crafting_skill[@name='craftingRepairTools']/effect_group">
		<passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,50" value="1" tags="modCreWeapDamageT1,modCreWeapDurabT1"/>
		<passive_effect name="CraftingTier" operation="base_add" level="10,20,30,40,50" value="1,2,3,4,5" tags="modCreWeapDamageT1,modCreWeapDurabT1"/>
	</append>


	<!-- ===== craftingBlades (max 75): Fire/Shock proc edges ===== -->
	<append xpath="//crafting_skill[@name='craftingBlades']/effect_group">
		<passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,75" value="1" tags="modCreMeleeFireT1,modCreMeleeShockT1"/>
		<passive_effect name="CraftingTier" operation="base_add" level="15,30,45,60,75" value="1,2,3,4,5" tags="modCreMeleeFireT1,modCreMeleeShockT1"/>
	</append>


	<!-- ===== craftingClubs (max 75): APM, Range, Stamina ===== -->
	<append xpath="//crafting_skill[@name='craftingClubs']/effect_group">
		<passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,75" value="1" tags="modCreMeleeAPMT1,modCreMeleeRangeT1,modCreMeleeStaminaT1"/>
		<passive_effect name="CraftingTier" operation="base_add" level="15,30,45,60,75" value="1,2,3,4,5" tags="modCreMeleeAPMT1,modCreMeleeRangeT1,modCreMeleeStaminaT1"/>
	</append>


	<!-- ===== craftingSledgehammers (max 75): Block, Break ===== -->
	<append xpath="//crafting_skill[@name='craftingSledgehammers']/effect_group">
		<passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,75" value="1" tags="modCreMeleeBlockT1,modCreMeleeBreakT1"/>
		<passive_effect name="CraftingTier" operation="base_add" level="15,30,45,60,75" value="1,2,3,4,5" tags="modCreMeleeBlockT1,modCreMeleeBreakT1"/>
	</append>


	<!-- ===== craftingBows (max 75): String, Power ===== -->
	<append xpath="//crafting_skill[@name='craftingBows']/effect_group">
		<passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,75" value="1" tags="modCreBowStringT1,modCreBowPowerT1"/>
		<passive_effect name="CraftingTier" operation="base_add" level="15,30,45,60,75" value="1,2,3,4,5" tags="modCreBowStringT1,modCreBowPowerT1"/>
	</append>


	<!-- ===== craftingHandguns (max 100): Reload, Grip, Shock ===== -->
	<append xpath="//crafting_skill[@name='craftingHandguns']/effect_group">
		<passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,100" value="1" tags="modCreGunReloadT1,modCreGunGripT1,modCreGunShockT1"/>
		<passive_effect name="CraftingTier" operation="base_add" level="20,40,60,80,100" value="1,2,3,4,5" tags="modCreGunReloadT1,modCreGunGripT1,modCreGunShockT1"/>
	</append>


	<!-- ===== craftingShotguns (max 100): OneB single-shot conversion ===== -->
	<append xpath="//crafting_skill[@name='craftingShotguns']/effect_group">
		<passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,100" value="1" tags="modCreGunOneBT1"/>
		<passive_effect name="CraftingTier" operation="base_add" level="20,40,60,80,100" value="1,2,3,4,5" tags="modCreGunOneBT1"/>
	</append>


	<!-- ===== craftingRifles (max 100): Sniper, Range, Blood ===== -->
	<append xpath="//crafting_skill[@name='craftingRifles']/effect_group">
		<passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,100" value="1" tags="modCreGunSniperT1,modCreGunRangeT1,modCreGunBloodT1"/>
		<passive_effect name="CraftingTier" operation="base_add" level="20,40,60,80,100" value="1,2,3,4,5" tags="modCreGunSniperT1,modCreGunRangeT1,modCreGunBloodT1"/>
	</append>


	<!-- ===== craftingMachineGuns (max 100): RPM, Magazine ===== -->
	<append xpath="//crafting_skill[@name='craftingMachineGuns']/effect_group">
		<passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,100" value="1" tags="modCreGunRPMT1,modCreGunMagazineT1"/>
		<passive_effect name="CraftingTier" operation="base_add" level="20,40,60,80,100" value="1,2,3,4,5" tags="modCreGunRPMT1,modCreGunMagazineT1"/>
	</append>


	<!-- ===== craftingArmor (max 100): all 16 cre_modArmor* ===== -->
	<append xpath="//crafting_skill[@name='craftingArmor']/effect_group">
		<passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,100" value="1" tags="cre_modArmorBandolierT1,cre_modArmorFittingsT1,cre_modArmorPlatingT1,cre_modArmorGlovesStaminaT1,cre_modArmorGlovesSpeedT1,cre_modArmorBootsSpeedT1,cre_modArmorBootsStorageT1,cre_modArmorHealthT1,cre_modArmorStaminaT1,cre_modArmorResistT1,cre_modArmorReflectionShockT1,cre_modArmorReflectionPunchT1,cre_modArmorReflectionFireT1,cre_modArmorAddLootT1,cre_modArmorBleedAnimalT1,cre_modArmorSniperT1"/>
		<passive_effect name="CraftingTier" operation="base_add" level="20,40,60,80,100" value="1,2,3,4,5" tags="cre_modArmorBandolierT1,cre_modArmorFittingsT1,cre_modArmorPlatingT1,cre_modArmorGlovesStaminaT1,cre_modArmorGlovesSpeedT1,cre_modArmorBootsSpeedT1,cre_modArmorBootsStorageT1,cre_modArmorHealthT1,cre_modArmorStaminaT1,cre_modArmorResistT1,cre_modArmorReflectionShockT1,cre_modArmorReflectionPunchT1,cre_modArmorReflectionFireT1,cre_modArmorAddLootT1,cre_modArmorBleedAnimalT1,cre_modArmorSniperT1"/>
	</append>

</configs>
