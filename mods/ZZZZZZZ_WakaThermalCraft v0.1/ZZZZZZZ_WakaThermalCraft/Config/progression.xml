<?xml version="1.0" encoding="UTF-8" ?>
<configs>
    <!--
        Append clothing T1-T3 display_entry to vanilla craftingArmor skill.
        unlock_level mirrors vanilla armor scale:
          T1 (Primitive parity): 1,2,4,6,8,10
          T2 (Light armor parity): 11,20,40,60,80,100
          T3 (Medium armor parity): 11,20,40,60,80,100
        name_key reuses vanilla armorTx (categorized as armor in skill UI).
    -->
    <append xpath="/progression/crafting_skills/crafting_skill[@name='craftingArmor']">

        <display_entry icon="clothingHeadT1" name_key="armorT1" has_quality="true" unlock_level="1,2,4,6,8,10">
            <unlock_entry item="clothingOutfitT1" unlock_tier="1" recipes="clothingHeadT1,clothingOutfitT1,clothingHandsT1,clothingFeetT1"/>
        </display_entry>

        <display_entry icon="clothingHeadT2" name_key="armorT2" has_quality="true" unlock_level="11,20,40,60,80,100">
            <unlock_entry item="clothingOutfitT2" unlock_tier="1" recipes="clothingHeadT2,clothingOutfitT2,clothingHandsT2,clothingFeetT2"/>
        </display_entry>

        <display_entry icon="clothingHeadT3" name_key="armorT3" has_quality="true" unlock_level="11,20,40,60,80,100">
            <unlock_entry item="clothingOutfitT3" unlock_tier="1" recipes="clothingHeadT3,clothingOutfitT3,clothingHandsT3,clothingFeetT3"/>
        </display_entry>

        <effect_group>
            <passive_effect name="RecipeTagUnlocked" operation="base_set" level="1,100" value="1" tags="clothingHeadT1,clothingOutfitT1,clothingHandsT1,clothingFeetT1"/>
            <passive_effect name="RecipeTagUnlocked" operation="base_set" level="11,100" value="1" tags="clothingHeadT2,clothingOutfitT2,clothingHandsT2,clothingFeetT2,clothingHeadT3,clothingOutfitT3,clothingHandsT3,clothingFeetT3"/>

            <passive_effect name="CraftingTier" operation="base_add" level="2,4,6,8,10,100" value="1,2,3,4,5,5" tags="clothingHeadT1,clothingOutfitT1,clothingHandsT1,clothingFeetT1"/>
            <passive_effect name="CraftingTier" operation="base_add" level="20,40,60,80,100" value="1,2,3,4,5" tags="clothingHeadT2,clothingOutfitT2,clothingHandsT2,clothingFeetT2,clothingHeadT3,clothingOutfitT3,clothingHandsT3,clothingFeetT3"/>
        </effect_group>

    </append>
</configs>
