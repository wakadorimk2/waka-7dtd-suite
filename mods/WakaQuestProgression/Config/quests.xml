<configs>

	<!-- ================================================================ -->
	<!-- POI tier-aware Infestation quests.                                -->
	<!-- WakaItemActionStartScourgeQuest reads the current POI's tier      -->
	<!-- (clamped 1..6) and starts quest_scourge_infestation_t{N}.         -->
	<!-- Each carries difficulty_tier=N and add_to_tier_complete=true so   -->
	<!-- finishing the infested clear contributes to trader tier complete  -->
	<!-- proportional to POI difficulty (1 unit at T1 ... 6 units at T6).  -->
	<!-- All other properties mirror POI Scourge's quest_scourge_infestation -->
	<!-- (RallyPoint phase 1 + ClearSleepers phase 2 + Exp 5000 reward).   -->
	<!-- ================================================================ -->

	<append xpath="/quests">

		<quest id="quest_scourge_infestation_t1">
			<property name="group_name_key" value="scourge_group_challenge"/>
			<property name="name_key" value="scourgeInfestationBeacon"/>
			<property name="subtitle_key" value="quest_scourge_infestation_subtitle"/>
			<property name="description_key" value="quest_scourge_infestation_description"/>
			<property name="icon" value="ui_game_symbol_quest"/>
			<property name="repeatable" value="true"/>
			<property name="category_key" value="quest"/>
			<property name="difficulty_tier" value="1"/>
			<property name="extra_tags" value="infested"/>
			<property name="spawn_multiplier" value="2"/>
			<property name="gamestage_mod" value="0.6"/>
			<property name="gamestage_bonus" value="30"/>
			<property name="completiontype" value="AutoComplete"/>
			<property name="add_to_tier_complete" value="true"/>

			<objective type="RallyPoint">
				<property name="phase" value="1"/>
				<property name="nav_object" value="rally"/>
				<property name="rally_marker_type" value="questRallyMarkerInfestation"/>
			</objective>

			<objective type="ClearSleepers">
				<property name="phase" value="2"/>
				<property name="nav_object" value="sleeper_volume"/>
			</objective>

			<reward type="Exp" value="5000"/>
		</quest>

		<quest id="quest_scourge_infestation_t2">
			<property name="group_name_key" value="scourge_group_challenge"/>
			<property name="name_key" value="scourgeInfestationBeacon"/>
			<property name="subtitle_key" value="quest_scourge_infestation_subtitle"/>
			<property name="description_key" value="quest_scourge_infestation_description"/>
			<property name="icon" value="ui_game_symbol_quest"/>
			<property name="repeatable" value="true"/>
			<property name="category_key" value="quest"/>
			<property name="difficulty_tier" value="2"/>
			<property name="extra_tags" value="infested"/>
			<property name="spawn_multiplier" value="2"/>
			<property name="gamestage_mod" value="0.6"/>
			<property name="gamestage_bonus" value="30"/>
			<property name="completiontype" value="AutoComplete"/>
			<property name="add_to_tier_complete" value="true"/>

			<objective type="RallyPoint">
				<property name="phase" value="1"/>
				<property name="nav_object" value="rally"/>
				<property name="rally_marker_type" value="questRallyMarkerInfestation"/>
			</objective>

			<objective type="ClearSleepers">
				<property name="phase" value="2"/>
				<property name="nav_object" value="sleeper_volume"/>
			</objective>

			<reward type="Exp" value="5000"/>
		</quest>

		<quest id="quest_scourge_infestation_t3">
			<property name="group_name_key" value="scourge_group_challenge"/>
			<property name="name_key" value="scourgeInfestationBeacon"/>
			<property name="subtitle_key" value="quest_scourge_infestation_subtitle"/>
			<property name="description_key" value="quest_scourge_infestation_description"/>
			<property name="icon" value="ui_game_symbol_quest"/>
			<property name="repeatable" value="true"/>
			<property name="category_key" value="quest"/>
			<property name="difficulty_tier" value="3"/>
			<property name="extra_tags" value="infested"/>
			<property name="spawn_multiplier" value="2"/>
			<property name="gamestage_mod" value="0.6"/>
